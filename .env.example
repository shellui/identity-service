# JWT signing (RS256 + JWKS)
# Required in production (DEBUG=false). Generate with: python manage.py generate_jwt_keys
# PEM with literal \n for newlines, e.g. JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=
# Optional: keep previous public key in JWKS during rotation
JWT_PREVIOUS_PUBLIC_KEY=
JWT_PREVIOUS_KEY_ID=
# Set false after all clients verify RS256 and old HS256 tokens have expired
JWT_ACCEPT_HS256_LEGACY=true

# App runtime
# Required. Used to sign Django sessions and CSRF tokens. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-12345678901234567890123456789012
IDENTITY_SERVICE_PORT=8000
DEBUG=true
# Comma-separated hostnames, no scheme (e.g. localhost,127.0.0.1,app.example.com)
ALLOWED_HOSTS=
# Comma-separated full URLs with scheme (e.g. https://app.example.com)
CSRF_TRUSTED_ORIGINS=
POSTGRES_DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5174,https://admin.shellui.com

# Gunicorn tuning
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
