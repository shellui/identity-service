# App runtime
IDENTITY_SERVICE_PORT=8000
DEBUG=false
# Comma-separated hostnames, no scheme (e.g. localhost,127.0.0.1,app.example.com)
ALLOWED_HOSTS=
# Comma-separated full URLs with scheme (e.g. https://app.example.com)
CSRF_TRUSTED_ORIGINS=
POSTGRES_DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5174

# OAuth providers (set as needed)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Gunicorn tuning
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
